<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".sample.designsystem.presentation.ui.DesignSystemFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_16sdp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/design_system_headline_sample"
            android:textAppearance="@style/TextAppearance.AndroidXmlBase.Headline" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_8sdp"
            android:text="@string/design_system_body_sample"
            android:textAppearance="@style/TextAppearance.AndroidXmlBase.Body" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_4sdp"
            android:text="@string/design_system_caption_sample"
            android:textAppearance="@style/TextAppearance.AndroidXmlBase.Caption" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_4sdp"
            android:text="@string/design_system_body_emphasis_sample"
            android:textAppearance="@style/TextAppearance.AndroidXmlBase.BodyEmphasis" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_4sdp"
            android:text="@string/design_system_body_medium_sample"
            android:textAppearance="@style/TextAppearance.AndroidXmlBase.BodyMedium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_4sdp"
            android:text="@string/design_system_micro_sample"
            android:textAppearance="@style/TextAppearance.AndroidXmlBase.Micro" />

        <!-- FrameButton #1: primary filled -->
        <com.thanhng224.androidxmlbase.core.ui.components.FrameButton
            android:layout_width="match_parent"
            android:layout_height="@dimen/_48sdp"
            android:layout_marginTop="@dimen/_16sdp"
            app:buttonBackgroundColor="@color/color_primary"
            app:buttonCornerRadius="@dimen/_8sdp"
            app:buttonShape="rectangle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/design_system_primary_button"
                android:textColor="@color/color_on_primary" />

        </com.thanhng224.androidxmlbase.core.ui.components.FrameButton>

        <!-- FrameButton #2: outlined -->
        <com.thanhng224.androidxmlbase.core.ui.components.FrameButton
            android:layout_width="match_parent"
            android:layout_height="@dimen/_48sdp"
            android:layout_marginTop="@dimen/_12sdp"
            app:buttonBackgroundColor="@color/color_surface"
            app:buttonCornerRadius="@dimen/_8sdp"
            app:buttonShape="rectangle"
            app:buttonStrokeColor="@color/color_primary"
            app:buttonStrokeWidth="@dimen/_1sdp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/design_system_outlined_button"
                android:textColor="@color/color_primary" />

        </com.thanhng224.androidxmlbase.core.ui.components.FrameButton>

        <!--
            ShadowLayout's shadow only renders where the caller sets android:elevation on the
            instance itself (it does not force its own elevation internally) — see Phase 5 Task A
            notes.
        -->
        <com.thanhng224.androidxmlbase.core.ui.components.ShadowLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp"
            android:elevation="@dimen/_4sdp"
            app:shadowBackgroundColor="@color/color_surface"
            app:shadowCornerRadius="@dimen/_8sdp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/_16sdp"
                android:text="@string/design_system_shadow_card_text"
                android:textAppearance="@style/TextAppearance.AndroidXmlBase.Body" />

        </com.thanhng224.androidxmlbase.core.ui.components.ShadowLayout>

        <com.thanhng224.androidxmlbase.core.ui.components.ThemedSwitch
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp"
            android:text="@string/design_system_switch_label" />

        <!-- FrameButton #3: triggers StyledSnackbar -->
        <com.thanhng224.androidxmlbase.core.ui.components.FrameButton
            android:id="@+id/btnShowSnackbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_48sdp"
            android:layout_marginTop="@dimen/_16sdp"
            app:buttonBackgroundColor="@color/color_primary"
            app:buttonCornerRadius="@dimen/_8sdp"
            app:buttonShape="rectangle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/design_system_show_snackbar"
                android:textColor="@color/color_on_primary" />

        </com.thanhng224.androidxmlbase.core.ui.components.FrameButton>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp"
            android:text="@string/design_system_result_demo_title"
            android:textAppearance="@style/TextAppearance.AndroidXmlBase.Caption" />

        <LinearLayout
            style="?android:attr/buttonBarStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_8sdp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnShowLoading"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/design_system_loading_button" />

            <Button
                android:id="@+id/btnShowSuccess"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_8sdp"
                android:layout_weight="1"
                android:text="@string/design_system_success_button" />

            <Button
                android:id="@+id/btnShowError"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_8sdp"
                android:layout_weight="1"
                android:text="@string/design_system_error_button" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                android:id="@+id/progressDemoResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/_8sdp" />

            <TextView
                android:id="@+id/tvDemoResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textAppearance="@style/TextAppearance.AndroidXmlBase.Body" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
