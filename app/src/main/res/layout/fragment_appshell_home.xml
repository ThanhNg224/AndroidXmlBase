<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".appshell.home.HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/_24sdp"
        android:paddingTop="@dimen/_24sdp"
        android:paddingBottom="@dimen/_32sdp">

        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/appshell_home_greeting"
            android:textAppearance="@style/TextAppearance.AndroidXmlBase.Headline" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_8sdp"
            android:text="@string/appshell_home_subtitle"
            android:textAppearance="@style/TextAppearance.AndroidXmlBase.BodyMedium" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_32sdp"
            app:cardBackgroundColor="@color/color_primary_container"
            app:cardCornerRadius="@dimen/_24sdp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/_24sdp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_card_eyebrow"
                    android:textAllCaps="true"
                    android:textAppearance="@style/TextAppearance.AndroidXmlBase.Micro"
                    android:textColor="@color/color_on_primary_container" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_8sdp"
                    android:text="@string/home_card_title"
                    android:textAppearance="@style/TextAppearance.AndroidXmlBase.BodyEmphasis"
                    android:textColor="@color/color_on_primary_container" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_8sdp"
                    android:text="@string/home_card_body"
                    android:textAppearance="@style/TextAppearance.AndroidXmlBase.Body"
                    android:textColor="@color/color_on_primary_container" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_24sdp"
            android:text="@string/home_navigation_hint"
            android:textAppearance="@style/TextAppearance.AndroidXmlBase.Caption"
            android:textColor="@color/color_on_surface_variant" />

    </LinearLayout>

</ScrollView>
