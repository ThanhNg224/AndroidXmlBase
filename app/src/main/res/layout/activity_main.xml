<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="@dimen/_24sdp">

        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/hello_android"
            android:textAppearance="@style/TextAppearance.AndroidXmlBase.Headline" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_8sdp"
            android:text="@string/main_subtitle"
            android:textAppearance="@style/TextAppearance.AndroidXmlBase.BodyMedium" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_24sdp"
            app:cardBackgroundColor="@color/color_surface"
            app:cardCornerRadius="@dimen/_16sdp"
            app:cardElevation="@dimen/_4sdp"
            app:strokeColor="@color/color_outline_variant"
            app:strokeWidth="@dimen/_1sdp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/_16sdp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/language_section_title"
                    android:textAppearance="@style/TextAppearance.AndroidXmlBase.BodyEmphasis" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_4sdp"
                    android:text="@string/language_section_subtitle"
                    android:textAppearance="@style/TextAppearance.AndroidXmlBase.BodyMedium" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/languageSelector"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_16sdp"
                    android:orientation="vertical"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLangSystem"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/_48sdp"
                        android:text="@string/language_system"
                        app:icon="@drawable/ic_language_selection"
                        app:iconGravity="textEnd"
                        app:iconPadding="@dimen/_8sdp"
                        app:iconSize="@dimen/_20sdp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLangEnglish"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/_48sdp"
                        android:text="@string/language_english"
                        app:icon="@drawable/ic_language_selection"
                        app:iconGravity="textEnd"
                        app:iconPadding="@dimen/_8sdp"
                        app:iconSize="@dimen/_20sdp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLangVietnamese"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/_48sdp"
                        android:text="@string/language_vietnamese"
                        app:icon="@drawable/ic_language_selection"
                        app:iconGravity="textEnd"
                        app:iconPadding="@dimen/_8sdp"
                        app:iconSize="@dimen/_20sdp" />

                </com.google.android.material.button.MaterialButtonToggleGroup>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.example.androidxmlbase.core.ui.components.FrameButton
            android:id="@+id/btnOpenDemo"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_48sdp"
            android:layout_marginTop="@dimen/_24sdp"
            app:buttonBackgroundColor="@color/color_primary"
            app:buttonCornerRadius="@dimen/_12sdp"
            app:buttonShape="rectangle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/view_demo"
                android:textAppearance="@style/TextAppearance.AndroidXmlBase.BodyEmphasis"
                android:textColor="@color/color_on_primary" />

        </com.example.androidxmlbase.core.ui.components.FrameButton>

        <com.example.androidxmlbase.core.ui.components.FrameButton
            android:id="@+id/btnDesignSystem"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_48sdp"
            android:layout_marginTop="@dimen/_12sdp"
            app:buttonBackgroundColor="@color/color_surface"
            app:buttonCornerRadius="@dimen/_12sdp"
            app:buttonShape="rectangle"
            app:buttonStrokeColor="@color/color_primary"
            app:buttonStrokeWidth="@dimen/_1sdp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/design_system_button"
                android:textAppearance="@style/TextAppearance.AndroidXmlBase.BodyEmphasis"
                android:textColor="@color/color_primary" />

        </com.example.androidxmlbase.core.ui.components.FrameButton>

    </LinearLayout>

</ScrollView>
