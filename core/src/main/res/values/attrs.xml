<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Shared shape/button attributes. Any custom View whose background is built via
        ShapeUtils.buildDrawable can reuse these instead of declaring near-duplicate attrs.
    -->
    <attr name="buttonBackgroundColor" format="color" />
    <attr name="buttonCornerRadius" format="dimension" />
    <attr name="buttonStrokeWidth" format="dimension" />
    <attr name="buttonStrokeColor" format="color" />
    <attr name="buttonShape" format="enum">
        <enum name="rectangle" value="0" />
        <enum name="oval" value="1" />
    </attr>

    <declare-styleable name="FrameButton">
        <attr name="buttonBackgroundColor" />
        <attr name="buttonCornerRadius" />
        <attr name="buttonStrokeWidth" />
        <attr name="buttonStrokeColor" />
        <attr name="buttonShape" />
    </declare-styleable>

    <declare-styleable name="ShadowLayout">
        <attr name="shadowCornerRadius" format="dimension" />
        <attr name="shadowBackgroundColor" format="color" />
    </declare-styleable>

</resources>
