<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.AndroidXmlBase" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorOnPrimary">@color/color_on_primary</item>
        <item name="colorPrimaryContainer">@color/color_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/color_on_primary_container</item>
        <item name="colorSecondary">@color/color_secondary</item>
        <item name="colorOnSecondary">@color/color_on_secondary</item>
        <item name="colorSecondaryContainer">@color/color_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/color_on_secondary_container</item>
        <item name="colorTertiary">@color/color_tertiary</item>
        <item name="colorOnTertiary">@color/color_on_tertiary</item>
        <item name="colorTertiaryContainer">@color/color_tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/color_on_tertiary_container</item>
        <item name="android:windowBackground">@color/color_background</item>
        <item name="colorSurface">@color/color_surface</item>
        <item name="colorOnSurface">@color/color_on_surface</item>
        <item name="colorSurfaceVariant">@color/color_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/color_on_surface_variant</item>
        <item name="colorOutline">@color/color_outline</item>
        <item name="colorOutlineVariant">@color/color_outline_variant</item>
        <item name="colorError">@color/color_error</item>
        <item name="colorOnError">@color/color_on_error</item>
        <item name="colorErrorContainer">@color/color_error_container</item>
        <item name="colorOnErrorContainer">@color/color_on_error_container</item>
        <item name="android:forceDarkAllowed" tools:targetApi="29">false</item>
        <item name="materialButtonStyle">@style/Widget.AndroidXmlBase.Button</item>
        <item name="android:buttonBarButtonStyle">@style/Widget.AndroidXmlBase.Button.TextButton</item>
        <!-- Explicit default (matches the system fallback, so no visual change today) so a
             future brand font is a one-line swap here instead of touching every text style. -->
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.AndroidXmlBase" parent="Base.Theme.AndroidXmlBase">
        <item name="android:statusBarColor">@color/color_surface</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.AndroidXmlBase.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/color_surface</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.AndroidXmlBase</item>
    </style>

    <style name="Theme.AndroidXmlBase.Transition" parent="Theme.AndroidXmlBase">
        <item name="android:windowAnimationStyle">@style/Animation_AndroidXmlBase_Transition</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>

    <!-- Custom base button style enabling text auto-wrap to prevent truncation -->
    <style name="Widget.AndroidXmlBase.Button" parent="Widget.Material3.Button">
        <item name="android:singleLine">false</item>
        <item name="android:maxLines">2</item>
        <item name="android:ellipsize">none</item>
    </style>

    <!-- Custom button bar text button style enabling text auto-wrap and reducing padding -->
    <style name="Widget.AndroidXmlBase.Button.TextButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:singleLine">false</item>
        <item name="android:maxLines">2</item>
        <item name="android:ellipsize">none</item>
        <item name="android:paddingLeft">@dimen/_4sdp</item>
        <item name="android:paddingRight">@dimen/_4sdp</item>
    </style>

    <!-- Shared button style enforcing 48dp height, 12dp corners, and icon styling. -->
    <style name="Widget.AndroidXmlBase.IconButton" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/_48sdp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/_13ssp</item>
        <item name="cornerRadius">@dimen/_12sdp</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">@dimen/_8sdp</item>
        <item name="iconSize">@dimen/_18sdp</item>
    </style>

    <style name="Widget.AndroidXmlBase.BottomNavigation" parent="Widget.Material3Expressive.BottomNavigationView">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="Widget.AndroidXmlBase.Toolbar" parent="Widget.Material3.Toolbar.Surface">
        <item name="colorControlNormal">@color/color_on_surface</item>
        <item name="navigationIconTint">@color/color_on_surface</item>
    </style>

    <!-- Dialog entry/exit animations -->
    <style name="Animation_AndroidXmlBase_Dialog_Slide" parent="android:Animation">
        <item name="android:windowEnterAnimation">@anim/dialog_slide_in</item>
        <item name="android:windowExitAnimation">@anim/dialog_slide_out</item>
    </style>

    <style name="Animation_AndroidXmlBase_Dialog_Scale" parent="android:Animation">
        <item name="android:windowEnterAnimation">@anim/dialog_scale_in</item>
        <item name="android:windowExitAnimation">@anim/dialog_scale_out</item>
    </style>

    <style name="Animation_AndroidXmlBase_Dialog_Fade" parent="android:Animation">
        <item name="android:windowEnterAnimation">@anim/transition_fade_in</item>
        <item name="android:windowExitAnimation">@anim/transition_fade_out</item>
    </style>

    <style name="Animation_AndroidXmlBase_Transition">
        <item name="android:activityOpenEnterAnimation">@anim/transition_fade_in</item>
        <item name="android:activityOpenExitAnimation">@anim/transition_no_animation</item>
        <item name="android:activityCloseEnterAnimation">@anim/transition_no_animation</item>
        <item name="android:activityCloseExitAnimation">@anim/transition_fade_out</item>
    </style>
</resources>
