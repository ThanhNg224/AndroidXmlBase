<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="@dimen/_24sdp">

    <!-- Prompt status indicator icon -->
    <ImageView
        android:id="@+id/ivPromptIcon"
        android:layout_width="@dimen/_48sdp"
        android:layout_height="@dimen/_48sdp"
        android:contentDescription="@null" />

    <!-- Prompt message text -->
    <TextView
        android:id="@+id/tvPromptMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_12sdp"
        android:gravity="center"
        android:textAppearance="@style/TextAppearance.AndroidXmlBase.BodyMedium" />

    <!-- Technical details / code (optional) -->
    <TextView
        android:id="@+id/tvPromptCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_4sdp"
        android:gravity="center"
        android:textAppearance="@style/TextAppearance.AndroidXmlBase.Micro"
        android:alpha="0.6" />

    <!-- Primary Action Button -->
    <com.thanhng224.androidxmlbase.core.ui.components.FrameButton
        android:id="@+id/btnPrimary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_50sdp"
        android:layout_marginTop="@dimen/_16sdp"
        app:buttonBackgroundColor="@color/color_primary"
        app:buttonCornerRadius="@dimen/_12sdp"
        app:buttonShape="rectangle">

        <TextView
            android:id="@+id/tvPrimaryText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textAppearance="@style/TextAppearance.AndroidXmlBase.BodyEmphasis"
            android:textColor="@color/color_on_primary" />

    </com.thanhng224.androidxmlbase.core.ui.components.FrameButton>

    <!-- Secondary Action Button -->
    <com.thanhng224.androidxmlbase.core.ui.components.FrameButton
        android:id="@+id/btnSecondary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_50sdp"
        android:layout_marginTop="@dimen/_8sdp"
        app:buttonBackgroundColor="@android:color/transparent"
        app:buttonShape="rectangle">

        <TextView
            android:id="@+id/tvSecondaryText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textAppearance="@style/TextAppearance.AndroidXmlBase.BodyEmphasis"
            android:textColor="@color/color_primary" />

    </com.thanhng224.androidxmlbase.core.ui.components.FrameButton>

</LinearLayout>
